# --- ElevenLabs (server-side only — NEVER exposed to the browser) ---
# Get this from your ElevenLabs account (Profile -> API Keys).
ELEVENLABS_API_KEY=

# The agent this dashboard manages. Created once from the dashboard;
# paste its id here (or the app stores it for you).
ELEVENLABS_AGENT_ID=

# Secret used to verify ElevenLabs tool-webhook calls (optional in local dev).
ELEVENLABS_WEBHOOK_SECRET=
